---
import '../styles/global.css'

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Aiadverts',
  alternateName: 'AI Adverts South Africa',
  url: 'https://aiadverts.co.za',
  logo: 'https://aiadverts.co.za/logo.svg',
  description:
    'Aiadverts creates cinematic AI-generated video and image adverts for South African businesses across Durban, Johannesburg, Cape Town and Pietermaritzburg.',
  foundingDate: '2024',
  areaServed: [
    'Durban',
    'Johannesburg',
    'Cape Town',
    'Pietermaritzburg',
    'Pretoria',
    'KwaZulu-Natal',
    'Gauteng',
    'Western Cape',
    'South Africa'
  ],
  knowsAbout: [
    'AI video advertising',
    'AI image advertising',
    'Cinematic product adverts',
    'Social media content creation',
    'Digital marketing South Africa',
    'AI content generation',
    'Brand advertising'
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    email: 'hello@aiadverts.co.za',
    availableLanguage: 'English',
    areaServed: 'ZA'
  },
  sameAs: [
    'https://www.instagram.com/aiadverts',
    'https://www.facebook.com/aiadverts',
    'https://www.tiktok.com/@aiadverts'
  ]
}

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Aiadverts',
  description:
    'AI advertising agency creating cinematic video and image adverts for South African businesses',
  url: 'https://aiadverts.co.za',
  email: 'hello@aiadverts.co.za',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Durban',
    addressRegion: 'KwaZulu-Natal',
    addressCountry: 'ZA'
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: -29.8587,
    longitude: 31.0218
  },
  areaServed: [
    { '@type': 'City', name: 'Durban' },
    { '@type': 'City', name: 'Johannesburg' },
    { '@type': 'City', name: 'Cape Town' },
    { '@type': 'City', name: 'Pietermaritzburg' },
    { '@type': 'Country', name: 'South Africa' }
  ],
  priceRange: 'R1,500 - R8,000',
  currenciesAccepted: 'ZAR',
  paymentAccepted: 'EFT, Credit Card',
  openingHours: 'Mo-Fr 08:00-17:00'
}

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Aiadverts',
  url: 'https://aiadverts.co.za',
  description: 'AI advertising agency for South African businesses',
  inLanguage: 'en-ZA',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://aiadverts.co.za/?s={search_term_string}',
    'query-input': 'required name=search_term_string'
  }
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'AI Video Adverts South Africa',
  description: 'Cinematic AI-generated video adverts for South African businesses',
  provider: {
    '@type': 'Organization',
    name: 'Aiadverts',
    url: 'https://aiadverts.co.za'
  },
  areaServed: 'South Africa',
  availableChannel: {
    '@type': 'ServiceChannel',
    serviceUrl: 'https://aiadverts.co.za'
  },
  offers: {
    '@type': 'Offer',
    price: '1500',
    priceCurrency: 'ZAR',
    priceSpecification: {
      '@type': 'PriceSpecification',
      minPrice: '1500',
      maxPrice: '8000',
      priceCurrency: 'ZAR'
    }
  }
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is AI advertising?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'AI advertising uses artificial intelligence to create professional video and image adverts — producing cinematic quality content in days at a fraction of traditional production costs.'
      }
    },
    {
      '@type': 'Question',
      name: 'How much do AI adverts cost in South Africa?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Our adverts start from R1,500 for a single cinematic video or image package. Monthly content packages start from R3,000 per month.'
      }
    },
    {
      '@type': 'Question',
      name: 'How long does it take to create an AI advert?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most adverts are delivered within 3 to 5 business days from receiving your brief and brand assets.'
      }
    },
    {
      '@type': 'Question',
      name: 'What businesses can use AI adverts?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Any business with a product or service to promote. We have created adverts for fragrance brands, skincare companies, restaurants, gaming brands, jewellers and more across South Africa.'
      }
    },
    {
      '@type': 'Question',
      name: 'Do I need to provide video or photography?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. We create everything from scratch — you only need to share your product details, brand assets and what you want to achieve.'
      }
    },
    {
      '@type': 'Question',
      name: 'Which areas in South Africa do you serve?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We serve businesses across all of South Africa including Durban, Johannesburg, Cape Town, Pietermaritzburg and Pretoria. All work delivered digitally so location is never a barrier.'
      }
    }
  ]
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://aiadverts.co.za' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://aiadverts.co.za/#services' },
    { '@type': 'ListItem', position: 3, name: 'Portfolio', item: 'https://aiadverts.co.za/#portfolio' },
    { '@type': 'ListItem', position: 4, name: 'Pricing', item: 'https://aiadverts.co.za/#pricing' },
    { '@type': 'ListItem', position: 5, name: 'Contact', item: 'https://aiadverts.co.za/#contact' }
  ]
}
---

<!doctype html>
<html lang="en-ZA">
  <head>
    <meta charset="UTF-8" />

    <!-- Primary Meta Tags -->
    <title>AI Adverts South Africa — Cinematic AI Advertising Agency | Aiadverts</title>
    <meta name="title" content="AI Adverts South Africa — Cinematic AI Advertising Agency | Aiadverts" />
    <meta
      name="description"
      content="Aiadverts creates cinematic AI-generated video and image adverts for South African businesses. Fast, affordable and stunning. Serving Durban, Johannesburg, Cape Town, Pietermaritzburg and all of South Africa."
    />
    <meta
      name="keywords"
      content="AI adverts South Africa, AI advertising agency Durban, AI video ads South Africa, cinematic adverts South Africa, social media advertising AI, AI content creation South Africa, AI adverts Johannesburg, AI advertising Cape Town, digital marketing agency Durban, video ads South Africa, AI marketing South Africa, affordable advertising South Africa, social media management Durban, content creation agency South Africa, AI adverts KZN, AI advertising KwaZulu-Natal"
    />
    <meta name="author" content="Aiadverts" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href="https://aiadverts.co.za" />

    <!-- GEO META TAGS — Critical for local SEO -->
    <meta name="geo.placename" content="Durban, Pietermaritzburg, Johannesburg, Cape Town, KwaZulu-Natal, South Africa" />
    <meta name="geo.position" content="-29.8587;31.0218" />
    <meta name="geo.region" content="ZA-KN" />
    <meta name="ICBM" content="-29.8587, 31.0218" />
    <meta name="DC.title" content="Aiadverts — AI Advertising Agency South Africa" />
    <meta name="DC.description" content="Cinematic AI-generated video and image adverts for South African businesses" />
    <meta name="DC.subject" content="AI Advertising, Digital Marketing, South Africa" />
    <meta name="DC.coverage" content="South Africa" />
    <meta name="DC.language" content="en-ZA" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://aiadverts.co.za" />
    <meta property="og:title" content="AI Adverts South Africa — Cinematic AI Advertising | Aiadverts" />
    <meta
      property="og:description"
      content="We create cinematic AI-generated video and image adverts for South African businesses. Fast, affordable and impossible to ignore."
    />
    <meta property="og:image" content="https://aiadverts.co.za/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Aiadverts — AI Advertising Agency South Africa" />
    <meta property="og:locale" content="en_ZA" />
    <meta property="og:site_name" content="Aiadverts" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://aiadverts.co.za" />
    <meta name="twitter:title" content="AI Adverts South Africa | Aiadverts" />
    <meta
      name="twitter:description"
      content="Cinematic AI-generated video and image adverts for South African businesses. Fast, affordable, stunning."
    />
    <meta name="twitter:image" content="https://aiadverts.co.za/og-image.jpg" />

    <!-- Mobile and Performance -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0066FF" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Inter font — preloaded stylesheet, font-display: swap, no render block -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      />
    </noscript>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body>
    <slot />
  </body>
</html>
