---
import Layout from '../layouts/Layout.astro'

const navLinks = [
  { href: '#home',      label: 'Home' },
  { href: '#services',  label: 'Services' },
  { href: '#portfolio', label: 'Portfolio' },
  { href: '#pricing',   label: 'Pricing' },
  { href: '#faq',       label: 'FAQ' },
  { href: '#contact',   label: 'Contact' }
]

const WHATSAPP = 'https://wa.me/27695600708'
const EMAIL    = 'mailto:vip@webafy.co.za'

const marqueeBrands = [
  'Scentimental',
  'True Organic',
  'Onikuma',
  'Pizza Boyz',
  'Cubed Coffee',
  'Marcos Jewellers'
]

const services = [
  {
    icon: '🎬',
    title: 'AI Video Adverts',
    body: 'Cinematic product videos, brand films and social media reels that stop the scroll. Created using our proprietary AI production pipeline — trusted by brands across Durban, Johannesburg and Cape Town.'
  },
  {
    icon: '📸',
    title: 'AI Image Adverts',
    body: 'Stunning product photography and creative brand imagery. Indistinguishable from a professional studio shoot. Available to businesses across South Africa.'
  },
  {
    icon: '📱',
    title: 'Social Media Management',
    body: 'Consistent, professional content posted across all your platforms every week. We handle everything so you can focus on your business.'
  }
]

const steps = [
  {
    num: '01',
    title: 'Brief Us',
    body: 'Tell us about your brand, your product and what you want to achieve. Takes 10 minutes.'
  },
  {
    num: '02',
    title: 'We Create',
    body: 'Our team produces your cinematic AI adverts using our advanced proprietary AI pipeline. Delivered in days, not weeks.'
  },
  {
    num: '03',
    title: 'You Post and Grow',
    body: 'Receive content ready to post. Watch your engagement, reach and sales grow immediately.'
  }
]

const portfolio = [
  { name: 'Scentimental',    industry: 'Fragrance' },
  { name: 'True Organic',    industry: 'Skincare',  embedUrl: 'https://www.youtube.com/embed/Iim0XWCyd8A' },
  { name: 'Onikuma',         industry: 'Gaming' },
  { name: 'Pizza Boyz',      industry: 'Food' },
  { name: 'Cubed Coffee',    industry: 'Food and Beverage' },
  { name: 'Marcos Jewellers',industry: 'Jewellery' }
]

const pricing = [
  {
    name: 'Starter',
    price: 'From R1,500',
    blurb: 'Perfect for a single cinematic AI advert package.',
    features: ['1 AI Video Advert', '3 AI Images', '2 Revisions', 'Delivered in 3–5 days'],
    popular: false
  },
  {
    name: 'Growth',
    price: 'From R3,000/mo',
    blurb: 'Consistent monthly AI content that grows your brand.',
    features: ['4 AI Video Adverts', '10 AI Images', 'Weekly posting', 'Monthly report'],
    popular: true
  },
  {
    name: 'Premium',
    price: 'From R8,000/mo',
    blurb: 'Full AI campaign management across all platforms.',
    features: ['8 AI Video Adverts', '20 AI Images', 'Full management', 'Strategy session', 'Priority support'],
    popular: false
  }
]

const whyItems = [
  { title: 'Faster than traditional production', body: 'Days, not weeks.' },
  { title: 'A fraction of the cost',             body: 'Professional quality at South African prices.' },
  { title: 'Cinematic quality',                  body: 'Your brand deserves to look incredible.' },
  { title: 'AI powered — future proof',           body: 'The most advanced AI advertising technology.' },
  { title: 'South African — we get your market', body: 'Durban, Johannesburg and Cape Town consumer behaviour built into every advert.' },
  { title: 'No contracts — start small, scale fast', body: 'Try one advert. If you love it, we grow together.' }
]

const faqs = [
  {
    q: 'What is AI advertising?',
    a: 'AI advertising uses artificial intelligence to create professional video and image adverts — producing cinematic quality content in days at a fraction of traditional production costs.'
  },
  {
    q: 'How much do AI adverts cost in South Africa?',
    a: 'Our adverts start from R1,500 for a single cinematic video or image package. Monthly content packages start from R3,000 per month.'
  },
  {
    q: 'How long does it take to create an AI advert?',
    a: 'Most adverts are delivered within 3 to 5 business days from receiving your brief and brand assets.'
  },
  {
    q: 'What businesses can use AI adverts?',
    a: 'Any business with a product or service to promote. We have created adverts for fragrance brands, skincare companies, restaurants, gaming brands, jewellers and more across South Africa.'
  },
  {
    q: 'Do I need to provide video or photography?',
    a: 'No. We create everything from scratch — you only need to share your product details, brand assets and what you want to achieve.'
  },
  {
    q: 'Which areas in South Africa do you serve?',
    a: 'We serve businesses across all of South Africa including Durban, Johannesburg, Cape Town, Pietermaritzburg and Pretoria. All work delivered digitally so location is never a barrier.'
  }
]

const statCards = [
  { icon: '💸', stat: 'R15,000+', label: 'Average traditional video shoot cost' },
  { icon: '⚡', stat: '3–5 Days', label: 'Our average delivery time' },
  { icon: '📉', stat: '70%',      label: 'Average cost saving vs traditional' }
]
---

<Layout>
  <!-- Skip link -->
  <a
    href="#main"
    class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-electric focus:px-4 focus:py-2 focus:text-text-light focus:font-semibold"
  >
    Skip to main content
  </a>

  <!-- ============ NAVIGATION ============ -->
  <header class="fixed inset-x-0 top-0 z-50">
    <nav
      aria-label="Primary navigation"
      class="mx-auto flex max-w-7xl items-center justify-between gap-4 border-b border-white/10 bg-bg-dark/75 px-5 py-3 backdrop-blur-xl sm:px-8"
    >
      <!-- Logo -->
      <a href="#home" aria-label="Aiadverts home" class="flex items-center gap-2">
        <span class="grid h-8 w-8 place-items-center rounded-lg bg-electric text-xs font-black text-white">A</span>
        <span class="text-lg font-extrabold tracking-tight text-electric">AIADVERTS</span>
      </a>

      <!-- Desktop links -->
      <ul class="hidden items-center gap-7 lg:flex">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              aria-label={`Go to ${link.label} section`}
              class="nav-link text-sm font-medium text-text-light/80 transition-colors hover:text-electric"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="flex items-center gap-2">
        <a
          href={WHATSAPP}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Get a free demo advert from Aiadverts"
          class="hidden rounded-full bg-electric px-5 py-2.5 text-sm font-semibold text-text-light shadow-lg shadow-electric/30 transition-all hover:scale-105 hover:shadow-electric/50 sm:inline-block"
        >
          Get a Free Demo
        </a>

        <!-- Hamburger -->
        <button
          id="menu-toggle"
          type="button"
          aria-label="Open navigation menu"
          aria-controls="mobile-menu"
          aria-expanded="false"
          class="grid h-11 w-11 place-items-center rounded-lg text-text-light lg:hidden"
        >
          <svg id="menu-open-icon" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="menu-close-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
            <line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden border-b border-white/10 bg-bg-dark/95 backdrop-blur-xl lg:hidden">
      <ul class="mx-auto flex max-w-7xl flex-col gap-1 px-5 py-4">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              aria-label={`Go to ${link.label} section`}
              class="mobile-link block rounded-lg px-3 py-3 text-base font-medium text-text-light/90 transition-colors hover:bg-white/5 hover:text-electric"
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="pt-2">
          <a
            href={WHATSAPP}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Get a free demo advert from Aiadverts"
            class="mobile-link block rounded-full bg-electric px-5 py-3 text-center text-base font-semibold text-text-light"
          >
            Get a Free Demo
          </a>
        </li>
      </ul>
    </div>
  </header>

  <main id="main">
    <!-- ============ HERO ============ -->
    <section id="home" class="hero-gradient relative flex min-h-[100svh] items-center overflow-hidden">
      <!-- Particles -->
      <div aria-hidden="true" class="pointer-events-none absolute inset-0">
        <span class="particle" style="width:10px;height:10px;left:8%;top:22%;animation-delay:0s"></span>
        <span class="particle" style="width:16px;height:16px;left:20%;top:65%;animation-delay:1.5s"></span>
        <span class="particle" style="width:8px;height:8px;left:38%;top:30%;animation-delay:3s"></span>
        <span class="particle" style="width:14px;height:14px;left:55%;top:70%;animation-delay:0.8s"></span>
        <span class="particle" style="width:10px;height:10px;left:72%;top:25%;animation-delay:2.2s"></span>
        <span class="particle" style="width:18px;height:18px;left:85%;top:60%;animation-delay:4s"></span>
        <span class="particle" style="width:9px;height:9px;left:90%;top:35%;animation-delay:1.1s"></span>
        <span class="particle" style="width:12px;height:12px;left:48%;top:50%;animation-delay:2.8s"></span>
        <span class="particle" style="width:7px;height:7px;left:62%;top:18%;animation-delay:3.6s"></span>
        <span class="particle" style="width:13px;height:13px;left:30%;top:80%;animation-delay:0.4s"></span>
      </div>

      <div class="relative mx-auto w-full max-w-5xl px-5 py-32 text-center sm:px-8">
        <!-- Label pill -->
        <span class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-text-light/80 backdrop-blur">
          <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-electric"></span>
          AI Advertising Agency · South Africa 🇿🇦
        </span>

        <!-- H1 with gradient on key phrase -->
        <h1 class="mx-auto max-w-4xl text-4xl font-black leading-[1.06] tracking-tight text-text-light sm:text-6xl lg:text-7xl">
          AI Adverts That Make Your Brand
          <span class="text-gradient block sm:inline"> Impossible to Ignore</span>
        </h1>

        <p class="mx-auto mt-7 max-w-2xl text-base leading-relaxed text-text-light/65 sm:text-xl">
          We create cinematic AI-generated video and image adverts for South African businesses —
          in days, not weeks, at a fraction of traditional costs.
        </p>

        <!-- Stats row -->
        <div class="mx-auto mt-10 flex flex-wrap items-center justify-center gap-6 text-sm text-text-light/60">
          <span class="flex items-center gap-1.5"><span class="text-electric font-bold">70%</span> cost saving</span>
          <span class="h-4 w-px bg-white/20" aria-hidden="true"></span>
          <span class="flex items-center gap-1.5"><span class="text-electric font-bold">3–5</span> day delivery</span>
          <span class="h-4 w-px bg-white/20" aria-hidden="true"></span>
          <span class="flex items-center gap-1.5"><span class="text-electric font-bold">100%</span> AI-generated</span>
        </div>

        <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
          <a
            href="#portfolio"
            aria-label="See our portfolio of AI adverts"
            class="w-full rounded-full bg-electric px-8 py-4 text-base font-semibold text-text-light shadow-xl shadow-electric/40 transition-all hover:scale-105 hover:shadow-electric/60 sm:w-auto"
          >
            See Our Work
          </a>
          <a
            href={WHATSAPP}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Contact Aiadverts on WhatsApp"
            class="w-full rounded-full border-2 border-white/30 px-8 py-4 text-base font-semibold text-text-light backdrop-blur transition-all hover:border-white/70 hover:bg-white/10 sm:w-auto"
          >
            💬 WhatsApp Us Now
          </a>
        </div>

        <!-- Scroll hint -->
        <div aria-hidden="true" class="mt-16 flex flex-col items-center gap-2 opacity-40">
          <span class="text-xs uppercase tracking-widest text-text-light">Scroll</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="animate-bounce text-text-light">
            <path d="M12 5v14M5 12l7 7 7-7"/>
          </svg>
        </div>

        <span class="sr-only">AI advertising agency serving Durban, Johannesburg, Cape Town and all of South Africa</span>
      </div>
    </section>

    <!-- Wave divider: hero → social proof -->
    <div aria-hidden="true" class="wave-divider -mt-1 bg-bg-light">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 C360,60 1080,0 1440,60 L1440,60 L0,60 Z" fill="#0A0A0A"/>
      </svg>
    </div>

    <!-- ============ SOCIAL PROOF BAR ============ -->
    <section aria-label="Trusted by South African businesses" class="bg-bg-light py-12">
      <p class="px-5 text-center text-sm font-bold uppercase tracking-widest text-navy/50">
        Trusted by businesses across South Africa 🇿🇦
      </p>
      <div class="marquee-wrap mt-8 overflow-hidden" aria-hidden="true">
        <div class="marquee-track gap-14 pr-14">
          {[...marqueeBrands, ...marqueeBrands].map((brand) => (
            <span class="whitespace-nowrap text-xl font-extrabold tracking-tight text-navy/30 sm:text-2xl">
              {brand}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- Wave divider: social proof → about -->
    <div aria-hidden="true" class="wave-divider bg-text-light">
      <svg viewBox="0 0 1440 50" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,50 C480,0 960,50 1440,0 L1440,50 L0,50 Z" fill="#F8F8F8"/>
      </svg>
    </div>

    <!-- ============ PROBLEM & SOLUTION ============ -->
    <section id="about" class="bg-text-light py-20 sm:py-28">
      <div class="mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-2 lg:gap-20">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-electric">The Problem</span>
          <h2 class="mt-3 text-3xl font-black leading-tight text-navy sm:text-4xl">
            Traditional Advertising<br />is Broken
          </h2>
          <div class="mt-6 space-y-4 text-base leading-relaxed text-text-dark/65 sm:text-lg">
            <p>
              Most South African businesses face the same problem. Professional video production
              costs R15,000 to R40,000 per shoot. Takes weeks to deliver. And the result? Content
              that looks exactly like everyone else's.
            </p>
            <p>
              There is a better way. Aiadverts uses proprietary AI technology to create cinematic,
              scroll-stopping adverts for businesses in Durban, Johannesburg, Cape Town,
              Pietermaritzburg and across South Africa.
            </p>
            <p class="font-bold text-navy">Faster. More affordable. More creative.</p>
          </div>
        </div>

        <!-- Enhanced stat cards with icons -->
        <div class="grid gap-5 sm:grid-cols-3 lg:grid-cols-1">
          {statCards.map((card) => (
            <div class="group rounded-2xl bg-electric p-6 text-text-light shadow-xl shadow-electric/20 transition-transform hover:-translate-y-1 hover:shadow-electric/35">
              <div class="stat-icon text-xl" aria-hidden="true">{card.icon}</div>
              <p class="text-3xl font-black sm:text-4xl">{card.stat}</p>
              <p class="mt-1.5 text-sm font-medium text-text-light/80">{card.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ SERVICES ============ -->
    <section id="services" class="bg-bg-light py-20 sm:py-28">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="text-center">
          <span class="text-xs font-bold uppercase tracking-widest text-electric">What We Do</span>
          <h2 class="mt-3 text-3xl font-black text-navy sm:text-4xl">
            What We Create For Your Business
          </h2>
        </div>

        <div class="mt-14 grid gap-8 md:grid-cols-3">
          {services.map((service) => (
            <article class="group rounded-2xl bg-text-light p-8 shadow-md transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl hover:shadow-electric/20">
              <!-- Gradient icon circle -->
              <div class="icon-circle" aria-hidden="true">{service.icon}</div>
              <h3 class="mt-5 text-xl font-bold text-navy">{service.title}</h3>
              <p class="mt-3 text-base leading-relaxed text-text-dark/65">{service.body}</p>
              <a
                href="#contact"
                aria-label={`Learn more about ${service.title}`}
                class="mt-5 inline-flex items-center gap-1.5 text-sm font-bold text-electric transition-all group-hover:gap-3"
              >
                Learn more <span aria-hidden="true">→</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Wave divider: services → how it works -->
    <div aria-hidden="true" class="wave-divider bg-bg-dark">
      <svg viewBox="0 0 1440 55" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 C360,55 1080,0 1440,55 L1440,55 L0,55 Z" fill="#F8F8F8"/>
      </svg>
    </div>

    <!-- ============ HOW IT WORKS ============ -->
    <section aria-labelledby="how-heading" class="bg-bg-dark py-20 sm:py-28">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="text-center">
          <span class="text-xs font-bold uppercase tracking-widest text-electric">The Process</span>
          <h2 id="how-heading" class="mt-3 text-3xl font-black text-text-light sm:text-4xl">
            How It Works
          </h2>
        </div>

        <div class="relative mt-16 grid gap-12 md:grid-cols-3 md:gap-8">
          <!-- Connecting line -->
          <div aria-hidden="true" class="absolute left-0 right-0 top-7 hidden h-px bg-gradient-to-r from-transparent via-electric/40 to-transparent md:block"></div>

          {steps.map((step, i) => (
            <div class="relative text-center md:text-left">
              <div class="mx-auto grid h-14 w-14 place-items-center rounded-2xl bg-electric/15 border border-electric/30 text-lg font-black text-electric md:mx-0">
                {step.num}
              </div>
              <h3 class="mt-5 text-xl font-bold text-text-light">{step.title}</h3>
              <p class="mt-3 text-base leading-relaxed text-text-light/60">{step.body}</p>
            </div>
          ))}
        </div>

        <div class="mt-14 rounded-2xl border border-amber/20 bg-amber/10 py-5 px-6 text-center">
          <p class="text-base font-semibold text-amber sm:text-lg">
            ✦ No long contracts &nbsp;·&nbsp; No complicated briefs &nbsp;·&nbsp; No waiting months
          </p>
        </div>
      </div>
    </section>

    <!-- Wave divider: how it works → portfolio -->
    <div aria-hidden="true" class="wave-divider bg-text-light">
      <svg viewBox="0 0 1440 55" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,55 C480,0 960,55 1440,0 L1440,55 L0,55 Z" fill="#0A0A0A"/>
      </svg>
    </div>

    <!-- ============ PORTFOLIO ============ -->
    <section id="portfolio" class="bg-text-light py-20 sm:py-28">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="text-center">
          <span class="text-xs font-bold uppercase tracking-widest text-electric">Our Work</span>
          <h2 class="mt-3 text-3xl font-black text-navy sm:text-4xl">
            Real Adverts. Real Brands. Real Results.
          </h2>
          <p class="mx-auto mt-4 max-w-2xl text-base text-text-dark/60 sm:text-lg">
            Every advert below was created entirely using our proprietary AI technology — no cameras,
            no studios, no traditional costs.
          </p>
        </div>

        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {portfolio.map((item) => (
            <article
              aria-label={`${item.name} — ${item.industry} AI advert by Aiadverts South Africa`}
              class="group relative aspect-[4/5] overflow-hidden rounded-2xl bg-bg-dark"
            >
              {item.embedUrl ? (
                /* ---- YouTube embed card ---- */
                <>
                  <iframe
                    src={item.embedUrl}
                    title={`${item.name} — ${item.industry} AI advert by Aiadverts`}
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                    loading="lazy"
                    class="absolute inset-0 h-full w-full border-0"
                  ></iframe>
                  {/* Industry badge */}
                  <div class="pointer-events-none absolute left-4 top-4 z-10">
                    <span class="rounded-full border border-white/10 bg-black/50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white/80 backdrop-blur-sm">
                      {item.industry}
                    </span>
                  </div>
                  {/* Name label */}
                  <div class="pointer-events-none absolute inset-x-0 bottom-0 z-10 bg-gradient-to-t from-black/70 to-transparent p-5">
                    <p class="text-lg font-bold text-text-light">{item.name}</p>
                  </div>
                </>
              ) : (
                /* ---- Shimmer placeholder card ---- */
                <>
                  <div class="portfolio-shimmer absolute inset-0"></div>
                  <div class="absolute inset-0 bg-gradient-to-t from-bg-dark/90 via-transparent to-bg-dark/20"></div>
                  <div class="absolute inset-0 grid place-items-center">
                    <span class="grid h-16 w-16 place-items-center rounded-full border border-white/20 bg-white/10 backdrop-blur-sm transition-all duration-300 group-hover:scale-110 group-hover:border-electric group-hover:bg-electric/80">
                      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </span>
                  </div>
                  <div class="absolute left-4 top-4">
                    <span class="rounded-full border border-white/10 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white/80 backdrop-blur-sm">
                      {item.industry}
                    </span>
                  </div>
                  <div class="absolute inset-x-0 bottom-0 p-5">
                    <p class="text-lg font-bold text-text-light">{item.name}</p>
                  </div>
                  <div class="absolute inset-0 grid place-items-center bg-electric/90 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                    <span class="flex items-center gap-2 text-lg font-bold text-text-light">
                      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                      View Project
                    </span>
                  </div>
                </>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

